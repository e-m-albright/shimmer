# =============================================================================
# Environment Variables
# =============================================================================
# Copy to .env and fill in your values. Never commit .env.
# =============================================================================

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# File storage (default, no setup needed):
SHIMMER_USE_FILE_STORAGE=1
SHIMMER_STORAGE_PATH=./shimmer-dev-storage

# S3/MinIO storage (requires `just up`):
# SHIMMER_S3_ENDPOINT=http://localhost:9000
# SHIMMER_S3_BUCKET=shimmer
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin

# -----------------------------------------------------------------------------
# Multi-tenancy
# -----------------------------------------------------------------------------
# Prefix for stored pastes (will use SSO user id when OIDC is integrated)
SHIMMER_USER_PREFIX=dev-user

# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------
# Override encryption key (64-char hex). Omit to auto-generate and persist.
# Generate with: openssl rand -hex 32
# SHIMMER_DEV_KEY=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# tracing filter (default: info)
RUST_LOG=info,shimmer_lib=debug
